{% extends 'base.html.twig' %}

{% block title %}Log in!{% endblock %}

{% block body %}

{% include "_partials/_header.html.twig" %}

    <div class="min-h-screen flex items-center justify-center bg-gray-100 font-sans"> 
        <form method="post" class="w-full max-w-sm bg-white p-6 rounded-lg shadow-lg">
            {% if error %}
                <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            {% if app.user %}
                <div class="mb-3 text-gray-800">
                    You are logged in as {{ app.user.userIdentifier }}, <a href="{{ path('app_logout') }}">Logout</a>
                </div>
            {% endif %}

            <h1 class="text-xl font-semibold text-gray-800 mb-6 text-center">Please sign in</h1>
            <div class="mb-4">
                <label for="username" class="block text-gray-700 font-medium pb-2">Email</label>
                <input type="email" value="{{ last_username }}" name="_username" id="username" autocomplete="email"  class="w-full mt-2 p-2 border border-gray-300 rounded-lg focus:border-teal-500 focus:ring-teal-500 focus:outline-none" required autofocus>
            </div>
            <div class="mb-4">
                <label for="password" class="block text-gray-700 font-medium pb-2">Password</label>
                <input type="password" name="_password" id="password" autocomplete="current-password" class="w-full mt-2 p-2 border border-gray-300 rounded-lg focus:border-teal-500 focus:ring-teal-500 focus:outline-none" required>
            </div>
            <input type="hidden" name="_csrf_token"
                value="{{ csrf_token('authenticate') }}"
            >

            {#
                Uncomment this section and add a remember_me option below your firewall to activate remember me functionality.
                See https://symfony.com/doc/current/security/remember_me.html

                <div class="checkbox mb-3">
                    <input type="checkbox" name="_remember_me" id="_remember_me">
                    <label for="_remember_me">Remember me</label>
                </div> 
            #}

            <button class="w-full bg-teal-500 hover:bg-teal-600 text-white mt-4 py-2 px-4 rounded-lg  focus:outline-none focus:ring-2 focus:ring-offset-2" type="submit">
                Sign in
            </button>
        </form>
    </div>
{% endblock %}
