{% extends 'base.html.twig' %}

{% block title %}Flashcard Form{% endblock %}

{% block body %}
<div class="min-h-screen flex flex-col items-center justify-center bg-gray-100 font-sans">
    <form method="post" class="w-full max-w-sm bg-white p-6 rounded-lg shadow-lg">
        <h1 class="text-xl font-semibold text-gray-800 mb-6 text-center">Flashcard Form</h1>
        {{ form_start(form) }}
            <div class="mb-4">
                <label for="question" class="block text-gray-700 font-medium pb-2">Question</label>
                {{ form_widget(form.question, {'attr': {'class': 'w-full mt-2 p-2 border border-gray-300 rounded-lg focus:border-teal-500 focus:ring-teal-500 focus:outline-none'}}) }}
            </div>
            <div class="mb-4">
                <label for="answer" class="block text-gray-700 font-medium pb-2">Answer</label>
                {{ form_widget(form.answer, {'attr': {'class': 'w-full mt-2 p-2 border border-gray-300 rounded-lg focus:border-teal-500 focus:ring-teal-500 focus:outline-none'}}) }}
            </div>
            <button class="w-full bg-teal-500 hover:bg-teal-600 text-white mt-4 py-2 px-4 rounded-lg focus:outline-none focus:ring-2 focus:ring-offset-2" type="submit">
                Submit
            </button>
        {{ form_end(form) }}
    </form>
</div>
{% endblock %}